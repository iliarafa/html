# AI design mode needs ONE of the following keys.

# Option A — Vercel AI Gateway key (preferred: one key, any model, fallbacks).
# Create at: https://vercel.com/[team]/~/ai-gateway/api-keys  (starts with vck_)
AI_GATEWAY_API_KEY=

# Option B — a direct Anthropic key (starts with sk-ant-). Used if no gateway key.
# ANTHROPIC_API_KEY=

# Optional model overrides:
# AI_MODEL=anthropic/claude-sonnet-4.6   # gateway "provider/model" id
# ANTHROPIC_MODEL=claude-sonnet-4-6      # direct Anthropic model id
